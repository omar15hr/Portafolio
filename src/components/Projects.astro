---
import GitHub from "./icons/GitHub.astro"
import NextJS from "./icons/NextJS.astro"
import Tailwind from "./icons/Tailwind.astro"
import Link from "./icons/Link.astro"
import LinkButton from "./LinkButton.astro"
import Postgres from "./icons/Postgres.astro"
import Typescript from "./icons/TypeScript.astro"
import React from "./icons/React.astro"
import Vite from "./icons/Vite.astro"

const TAGS = {
  NEXT: {
    name: "Next.js",
    class: "bg-black text-white",
    icon: NextJS,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-[#003159] text-white",
    icon: Tailwind,
  },
  POSTGRES: {
    name: "Postgres",
    class: "bg-[#003159] text-white",
    icon: Postgres,
  },
  TYPESCRIPT: {
    name: "Typescript",
    class: "bg-blue-800 text-white",
    icon: Typescript,
  },
  REACT: {
    name: "React",
    class: "bg-blue-800 text-white",
    icon: React,
  },
  VITE: {
    name: "Vite",
    class: "bg-blue-800 text-white",
    icon: Vite,
  },
}
const PROJECTS = [
  {
    title: "Muscari | Clothing",
    description:
      "Ecommerce creado desde cero con Next.js, React y Tailwind CSS. Tiene pasarela de pago y funciones de admin para el manejo de los productos y clientes.",
    link: "https://muscari.vercel.app/",
    github: "https://github.com/omar15hr/Muscari",
    image: "/projects/muscari.webp",
    tags: [TAGS.NEXT, TAGS.TAILWIND, TAGS.POSTGRES, TAGS.TYPESCRIPT],
  },
  {
    title: "Gif App",
    description:
      "Aplicación web para encontrar gifs de cualquier tipo de contenido. Desarrollada con Vite, Tailwind CSS, React y TypeScript.",
    link: "https://gif-app-omar.netlify.app",
    github: "https://github.com/omar15hr/GifApp",
    image: "/projects/gifApp.webp",
    tags: [TAGS.VITE, TAGS.TAILWIND, TAGS.REACT, TAGS.TYPESCRIPT],
  },
]
---

<div class="flex flex-col gap-y-16">
  {
    PROJECTS.map(({ image, title, description, tags, link, github }) => (
    <article class="flex flex-col space-x-0 space-y-8 group md:flex-row md:space-x-8 md:space-y-0">
  <div class="w-full md:w-1/2">
    <div class="relative flex flex-col items-center col-span-6 row-span-5 gap-8 transition duration-500 ease-in-out transform shadow-xl overflow-clip rounded-xl sm:rounded-xl md:group-hover:-translate-y-1 md:group-hover:shadow-2xl lg:border lg:border-gray-800 lg:hover:border-gray-700 lg:hover:bg-gray-800/50">
      <img alt="Recién llegado vs 5 años en Nueva Zelanda" class="object-cover object-top w-full h-56 transition duration-500 sm:h-full md:scale-110 md:group-hover:scale-105" loading="lazy" src={image} />
    </div>
  </div>

  <div class="w-full md:w-1/2 md:max-w-lg">
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
      {title}
    </h3>
    <div class="flex flex-wrap mt-2">
      <ul class="flex flex-row mb-2 gap-x-2">
          {tags.map((tag) => (
            <li>
              <span
                class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 `}
              >
                <tag.icon class="size-4" />
                {tag.name}
              </span>
            </li>
          ))}
        </ul>

      <div class="mt-2 text-gray-700 dark:text-gray-400">{description}</div>
      <footer class="flex items-end justify-start mt-4 gap-x-4">
          {github && (
            <LinkButton href={github}>
              <GitHub class="size-6" />
              Code
              
            </LinkButton>
          )}
          {link && (
            <LinkButton href={link}>
              <Link class="size-4" />
              Preview
            </LinkButton>
          )}
        </footer>
    </div>
  </div>
</article>
    ))
  }
</div>



